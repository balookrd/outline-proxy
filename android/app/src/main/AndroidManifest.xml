<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Needed to enumerate installed apps for the split-tunnel picker. VPN is
         an allowed use case for this permission. -->
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:label="Outline Proxy"
        android:supportsRtl="true"
        android:theme="@style/Theme.Material3.DayNight">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- External control over `outline://connect|disconnect|toggle`, for
             automation apps and shortcuts. Invisible (translucent theme) and
             kept out of the recents list; it finishes as soon as the command is
             dispatched. Anyone can send the intent, so the commands are gated
             in-app by the External control switch and optional token
             (see ExternalControl.kt). No `noHistory` here: it would kill the
             activity while the system VPN consent dialog is up and the result
             would never come back. -->
        <activity
            android:name=".ControlActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:taskAffinity=""
            android:theme="@android:style/Theme.Translucent.NoTitleBar">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <!-- BROWSABLE lets links, QR codes and launcher shortcuts fire
                     the scheme; it also lets a web page try, hence the token. -->
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="outline" />
            </intent-filter>
        </activity>

        <!-- The VPN tunnel service. BIND_VPN_SERVICE is granted to the system
             only; the special-use foreground type keeps the tunnel alive. -->
        <service
            android:name=".OutlineVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="vpn_tunnel" />
        </service>

    </application>
</manifest>
